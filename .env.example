# Set USE_SQLITE=1 to use a local SQLite file (no MySQL install needed).
USE_SQLITE=0
SQLITE_PATH=utpb_scheduler.db

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_DATABASE=utpb_scheduler

# Catalog year slug (must match a published undergraduate catalog)
CATALOG_YEAR=2025-2026

# Public class schedule (https://general.utpb.edu/schedule/) — term codes
# are linked from utpb.edu academics → registration → course schedules.
# Pipe-separated term:label pairs (verify codes each year on the registrar page).
SCHEDULE_TERM_MAP=2262:Spring 2026|2265:Summer 2026|2268:Fall 2026
# Single-term fallback if SCHEDULE_TERM_MAP is empty:
# SCHEDULE_TERM=2262
# SCHEDULE_SEMESTER_LABEL=Spring 2026
SCHEDULE_SUBJECT=COSC

# Anthropic Claude API (https://console.anthropic.com/) — schedule assistant
# Put the real key only in .env (never commit .env). Leave this line empty in .env.example.
ANTHROPIC_API_KEY=
# If this id 404s, the app retries dated Haiku then Sonnet automatically.
ANTHROPIC_MODEL=claude-haiku-4-5
# Optional (e.g. proxy): default is https://api.anthropic.com
# ANTHROPIC_BASE_URL=
